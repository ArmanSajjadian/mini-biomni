# ── LLM Configuration ─────────────────────────────────────────────────────────
# Model name passed to your inference server
NANO_LLM=llama3

# Ollama (default) — change port/host as needed
NANO_BASE_URL=http://localhost:11434

# Source: Ollama | Custom | Anthropic | OpenAI
# Use "Custom" for vLLM / SGLang / any OpenAI-compatible endpoint
NANO_SOURCE=Ollama

# For "Custom" (vLLM) example:
# NANO_SOURCE=Custom
# NANO_BASE_URL=http://localhost:8000/v1
# NANO_LLM=meta-llama/Llama-3-8B-Instruct

# ── Optional cloud API keys ────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Agent behaviour ────────────────────────────────────────────────────────────
# Pause before every tool call (true | false)
NANO_BREAKPOINTS=true

# Seconds before a tool call is force-killed
NANO_TIMEOUT_SECONDS=120

# Directory for intermediate data / downloads
NANO_DATA_PATH=./data
